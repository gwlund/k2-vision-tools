#!/usr/bin/env python3
"""Create a new Zotero collection."""

import sys
import click
from pathlib import Path

# Add library path
sys.path.insert(0, str(Path(__file__).parent.parent / 'lib'))

from zotero_api import ZoteroAPI
from rich.console import Console

console = Console()

@click.command()
@click.argument('name')
@click.option('--parent', help='Parent collection name (for subcollections)')
def create_collection(name: str, parent: str):
    """Create a new Zotero collection.

    Examples:
        zotero-create-collection "My Research Project"
        zotero-create-collection "Chapter 1" --parent "Dissertation"
    """

    try:
        api = ZoteroAPI()

        # Check if collection already exists
        if api.collection_exists(name):
            console.print(f"[yellow]⚠[/yellow]  Collection '{name}' already exists")

            # Get and display key
            key = api.get_collection_key(name)
            console.print(f"[dim]Key: {key}[/dim]")
            sys.exit(0)

        # Get parent key if specified
        parent_key = None
        if parent:
            parent_key = api.get_collection_key(parent)
            if not parent_key:
                console.print(f"[red]✗[/red] Parent collection '{parent}' not found")
                sys.exit(1)

        # Create collection
        key = api.create_collection(name, parent_key)

        if parent:
            console.print(f"[green]✓[/green] Created subcollection '{name}' under '{parent}'")
        else:
            console.print(f"[green]✓[/green] Created collection '{name}'")

        console.print(f"[dim]Key: {key}[/dim]")

    except Exception as e:
        console.print(f"[red]✗[/red] Error: {str(e)}")
        sys.exit(1)

if __name__ == '__main__':
    create_collection()
