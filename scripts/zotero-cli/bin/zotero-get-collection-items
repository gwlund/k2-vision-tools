#!/usr/bin/env python3
"""List all items in a specific Zotero collection."""

import sys
import argparse
from pathlib import Path

# Add lib to path
sys.path.insert(0, str(Path(__file__).parent.parent / 'lib'))

from zotero_api import ZoteroAPI
from rich.console import Console
from rich.table import Table
from rich.panel import Panel

console = Console()

def format_authors(creators):
    """Format author list from creators."""
    if not creators:
        return "Unknown"

    authors = [
        c.get('lastName', c.get('name', ''))
        for c in creators
        if c.get('creatorType') in ['author', 'creator']
    ]

    if len(authors) == 0:
        return "Unknown"
    elif len(authors) == 1:
        return authors[0]
    elif len(authors) == 2:
        return f"{authors[0]} & {authors[1]}"
    else:
        return f"{authors[0]} et al."

def display_items_table(items, collection_name, citekeys=None):
    """Display items in table format.

    Args:
        items: List of Zotero items
        collection_name: Name of the collection
        citekeys: Optional dict mapping item keys to citation keys
    """
    table = Table(title=f"Items in Collection: {collection_name}")
    table.add_column("#", justify="right", style="dim", width=4)
    table.add_column("Title", style="cyan")
    table.add_column("Authors", style="yellow", width=25)
    table.add_column("Year", justify="center", width=6)
    table.add_column("Type", width=12)
    table.add_column("Key", style="dim", width=10)

    # Add citation key column if citekeys provided
    if citekeys is not None:
        table.add_column("Citation Key", style="green", width=30)

    for i, item in enumerate(items, 1):
        data = item['data']
        item_key = data.get('key', '')

        row = [
            str(i),
            data.get('title', 'Untitled')[:60],
            format_authors(data.get('creators', []))[:25],
            data.get('date', '')[:4] if data.get('date') else 'n.d.',
            data.get('itemType', 'unknown'),
            item_key
        ]

        # Add citation key if available
        if citekeys is not None:
            citekey = citekeys.get(item_key, '')
            # Truncate long citation keys
            if len(citekey) > 28:
                citekey = citekey[:25] + '...'
            row.append(citekey)

        table.add_row(*row)

    return table

def display_items_full(items, collection_name, citekeys=None):
    """Display items with full details.

    Args:
        items: List of Zotero items
        collection_name: Name of the collection
        citekeys: Optional dict mapping item keys to citation keys
    """
    console.print(Panel(
        f"[bold]Items in Collection: {collection_name}[/bold]",
        border_style="blue"
    ))
    console.print()

    for i, item in enumerate(items, 1):
        data = item['data']

        title = data.get('title', 'Untitled')
        item_type = data.get('itemType', 'unknown')
        authors = format_authors(data.get('creators', []))
        year = data.get('date', 'n.d.')[:4] if data.get('date') else 'n.d.'
        key = data.get('key', '')

        content = f"[bold]{title}[/bold]\n"
        content += f"[cyan]{authors}[/cyan] ({year})\n"
        content += f"Type: {item_type} | Key: [dim]{key}[/dim]"

        # Add citation key if available
        if citekeys and key in citekeys:
            content += f"\n[green]Citation Key:[/green] {citekeys[key]}"

        if data.get('publicationTitle'):
            content += f"\nPublished in: {data['publicationTitle']}"

        if data.get('DOI'):
            content += f"\nDOI: {data['DOI']}"

        if data.get('tags'):
            tags = ', '.join(t['tag'] for t in data['tags'][:5])
            if len(data['tags']) > 5:
                tags += f" +{len(data['tags'])-5} more"
            content += f"\nTags: {tags}"

        console.print(Panel(content, title=f"[{i}]", border_style="cyan"))

def main():
    parser = argparse.ArgumentParser(
        description='List items in a specific Zotero collection'
    )
    parser.add_argument(
        'collection',
        help='Collection name or key'
    )
    parser.add_argument(
        '--format',
        choices=['table', 'full'],
        default='table',
        help='Output format (default: table)'
    )
    parser.add_argument(
        '--keys-only',
        action='store_true',
        help='Output only item keys (one per line)'
    )
    parser.add_argument(
        '--count',
        action='store_true',
        help='Show only the count of items'
    )
    parser.add_argument(
        '--include-citekey',
        action='store_true',
        help='Include Better BibTeX citation keys in output'
    )

    args = parser.parse_args()

    try:
        api = ZoteroAPI()

        # Get collection key
        if len(args.collection) == 8 and args.collection.isupper():
            collection_key = args.collection
            collection_name = args.collection
        else:
            collection_key = api.get_collection_key(args.collection)
            collection_name = args.collection
            if not collection_key:
                console.print(f"[red]Error:[/red] Collection '{args.collection}' not found")
                sys.exit(1)

        # Get items
        items = api.get_collection_items(collection_key)

        if not items:
            console.print(f"[yellow]No items in collection '{collection_name}'[/yellow]")
            sys.exit(0)

        # Get citation keys if requested
        citekeys = None
        if args.include_citekey:
            item_keys = [item['data']['key'] for item in items]
            citekeys = api.get_citation_keys(item_keys)

        # Output based on flags
        if args.count:
            print(len(items))
        elif args.keys_only:
            for item in items:
                print(item['data']['key'])
        elif args.format == 'full':
            display_items_full(items, collection_name, citekeys)
            console.print(f"\n[green]Total: {len(items)} items[/green]")
        else:
            table = display_items_table(items, collection_name, citekeys)
            console.print(table)
            console.print(f"\n[green]Total: {len(items)} items[/green]")

    except ValueError as e:
        console.print(f"[red]Error:[/red] {e}")
        sys.exit(1)
    except Exception as e:
        console.print(f"[red]Unexpected error:[/red] {e}")
        sys.exit(1)

if __name__ == '__main__':
    main()
