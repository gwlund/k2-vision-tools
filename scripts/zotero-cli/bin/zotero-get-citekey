#!/usr/bin/env python3
"""Get Better BibTeX citation key for a Zotero item."""

import sys
import argparse
import json
from pathlib import Path

# Add lib to path
sys.path.insert(0, str(Path(__file__).parent.parent / 'lib'))

from zotero_api import ZoteroAPI
from rich.console import Console

console = Console()


def main():
    parser = argparse.ArgumentParser(
        description='Get Better BibTeX citation key for a Zotero item'
    )
    parser.add_argument(
        'item_key',
        help='Zotero item key (8-character code)'
    )
    parser.add_argument(
        '--format',
        choices=['text', 'json'],
        default='text',
        help='Output format (default: text)'
    )

    args = parser.parse_args()

    try:
        api = ZoteroAPI()
        citation_key = api.get_citation_key(args.item_key)

        if not citation_key:
            if args.format == 'json':
                print(json.dumps({
                    'itemKey': args.item_key,
                    'citekey': None,
                    'error': 'No citation key found'
                }))
            else:
                console.print(f"[yellow]No citation key found for item {args.item_key}[/yellow]")
            sys.exit(1)

        if args.format == 'json':
            print(json.dumps({
                'itemKey': args.item_key,
                'citekey': citation_key
            }, indent=2))
        else:
            # Simple text output for easy scripting
            print(citation_key)

    except ValueError as e:
        console.print(f"[red]Error:[/red] {e}")
        sys.exit(1)
    except Exception as e:
        console.print(f"[red]Unexpected error:[/red] {e}")
        sys.exit(1)


if __name__ == '__main__':
    main()
