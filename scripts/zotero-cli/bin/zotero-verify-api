#!/usr/bin/env python3
"""Verify Zotero API credentials and test access."""

import os
import sys
from pyzotero import zotero
from rich.console import Console
from rich.panel import Panel

console = Console()

def verify_credentials():
    """Verify API credentials exist and work."""

    # Check environment variables
    api_key = os.getenv('ZOTERO_API_KEY')
    user_id = os.getenv('ZOTERO_USER_ID')

    if not api_key:
        console.print("[red]✗[/red] ZOTERO_API_KEY not found in environment")
        console.print("  Set it in ~/.zshrc: export ZOTERO_API_KEY=your_key")
        return False

    if not user_id:
        console.print("[red]✗[/red] ZOTERO_USER_ID not found in environment")
        console.print("  Set it in ~/.zshrc: export ZOTERO_USER_ID=your_id")
        return False

    console.print(f"[green]✓[/green] Found API credentials (User: {user_id})")

    # Test API connection
    try:
        zot = zotero.Zotero(user_id, 'user', api_key)

        # Test read access
        items = zot.top(limit=1)
        console.print(f"[green]✓[/green] Read access verified (found {zot.num_items()} items)")

        # Test collection access
        collections = zot.collections()
        console.print(f"[green]✓[/green] Collection access verified ({len(collections)} collections)")

        console.print()
        console.print(Panel.fit(
            "[bold green]Zotero API verification successful![/bold green]\n"
            "All write scripts will use these credentials.",
            title="Success"
        ))
        return True

    except Exception as e:
        console.print(f"[red]✗[/red] API connection failed: {str(e)}")
        return False

if __name__ == '__main__':
    success = verify_credentials()
    sys.exit(0 if success else 1)
