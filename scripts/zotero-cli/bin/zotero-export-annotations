#!/usr/bin/env python3
"""Export Zotero annotations to markdown."""

import sys
from pathlib import Path
import click

sys.path.insert(0, str(Path(__file__).parent.parent / 'lib'))

from zotero_api import ZoteroAPI
from annotation_export import (
    export_item_annotations,
    export_collection_annotations,
    export_cross_document_by_tag
)
from rich.console import Console

console = Console()


@click.command()
@click.argument('item_key', required=False)
@click.option('--output', type=click.Path(), help='Output file path')
@click.option('--output-dir', type=click.Path(), help='Output directory')
@click.option('--collection', help='Export all items in collection')
@click.option('--tag', help='Cross-document export by tag')
@click.option('--tag-filter', help='Only export annotations with this tag')
@click.option('--template', type=click.Path(exists=True), help='Obsidian template')
@click.option('--format', type=click.Choice(['markdown', 'json']), default='markdown')
@click.option('--include-images', is_flag=True, help='Extract and include images')
def export_annotations(item_key, output, output_dir, collection, tag,
                      tag_filter, template, format, include_images):
    """Export Zotero annotations to markdown.

    Examples:
        zotero-export-annotations ABC123 --output notes/asheville.md
        zotero-export-annotations --collection "CEDS" --output-dir notes/
        zotero-export-annotations --tag "tourism" --output notes/tourism.md
    """

    try:
        api = ZoteroAPI()

        # Single item export
        if item_key:
            if not output:
                console.print("[red]✗[/red] --output required for single item")
                sys.exit(1)

            console.print(f"[dim]Exporting annotations for {item_key}...[/dim]")
            count = export_item_annotations(
                api, item_key, Path(output), tag_filter,
                Path(template) if template else None
            )
            console.print(f"[green]✓[/green] Exported {count} annotations to {output}")

        # Collection export
        elif collection:
            if not output_dir:
                console.print("[red]✗[/red] --output-dir required for collection")
                sys.exit(1)

            console.print(f"[dim]Exporting collection: {collection}...[/dim]")
            results = export_collection_annotations(
                api, collection, Path(output_dir), tag_filter
            )

            total = sum(results.values())
            console.print(f"[green]✓[/green] Exported {total} annotations from {len(results)} items")
            console.print(f"[dim]Output directory: {output_dir}[/dim]")

        # Cross-document by tag
        elif tag:
            if not output:
                console.print("[red]✗[/red] --output required for tag export")
                sys.exit(1)

            console.print(f"[dim]Exporting annotations tagged: {tag}...[/dim]")
            count = export_cross_document_by_tag(
                api, tag, Path(output)
            )
            console.print(f"[green]✓[/green] Exported {count} annotations to {output}")

        else:
            console.print("[red]✗[/red] Must specify item_key, --collection, or --tag")
            sys.exit(1)

    except Exception as e:
        console.print(f"[red]✗[/red] Error: {str(e)}")
        import traceback
        traceback.print_exc()
        sys.exit(1)


if __name__ == '__main__':
    export_annotations()
